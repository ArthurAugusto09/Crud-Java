<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.MainController">
   <children>
      <Pane layoutY="-13.0" prefHeight="473.0" prefWidth="600.0" style="-fx-background-color: lightBlue;">
         <children>
            <Button fx:id="btnSalvar" layoutX="117.0" layoutY="196.0" mnemonicParsing="false" onAction="#btnSalvarAction" prefHeight="27.0" prefWidth="67.0" style="-fx-background-color: lightgreen; -fx-border-color: black;" text="Salvar" />
            <Button fx:id="btnEditar" layoutX="218.0" layoutY="196.0" mnemonicParsing="false" onAction="#btnEditarAction" prefHeight="27.0" prefWidth="67.0" style="-fx-background-color: Blue; -fx-border-color: black;" text="Editar" textFill="WHITE" />
            <Button fx:id="btnDeletar" layoutX="429.0" layoutY="196.0" mnemonicParsing="false" onAction="#btnDeletarAction" prefHeight="27.0" prefWidth="67.0" style="-fx-background-color: red; -fx-border-color: black;" text="Deletar" textFill="WHITE" />
            <Label layoutX="47.0" layoutY="100.0" text="Nome">
               <font>
                  <Font name="Arial" size="12.0" />
               </font>
            </Label>
            <Label layoutX="33.0" layoutY="136.0" text="Plataforma">
               <font>
                  <Font name="Arial" size="12.0" />
               </font>
            </Label>
            <Label layoutX="322.0" layoutY="95.0" text="Conteudo">
               <font>
                  <Font name="Arial" size="12.0" />
               </font>
            </Label>
            <Label layoutX="301.0" layoutY="131.0" text="N° Seguidores">
               <font>
                  <Font name="Arial" size="12.0" />
               </font>
            </Label>
            <TextField fx:id="txtNome" layoutX="100.0" layoutY="96.0" style="-fx-border-color: black;" />
            <TableView fx:id="tblStreamer" layoutX="44.0" layoutY="246.0" onMouseClicked="#carregarCampos" prefHeight="213.0" prefWidth="524.0" style="-fx-border-color: black; -fx-background-color: Beige;">
              <columns>
                <TableColumn fx:id="colId" prefWidth="48.0" text="ID" />
                <TableColumn fx:id="colNome" prefWidth="82.0" text="Nome" />
                  <TableColumn fx:id="colConteudo" prefWidth="95.0" text="Conteudo" />
                  <TableColumn fx:id="colPlataforma" prefWidth="75.0" text="Plataforma" />
                  <TableColumn fx:id="colSeguidores" prefWidth="75.0" text="Seguidores" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <TextField fx:id="txtPlataforma" layoutX="100.0" layoutY="132.0" style="-fx-border-color: black;" />
            <TextField fx:id="txtConteudo" layoutX="386.0" layoutY="91.0" style="-fx-border-color: black;" />
            <TextField fx:id="txtSeguidores" layoutX="386.0" layoutY="127.0" style="-fx-border-color: black;" />
            <Button fx:id="btnLimpar" layoutX="323.0" layoutY="196.0" mnemonicParsing="false" onAction="#btnEditarAction" prefHeight="27.0" prefWidth="67.0" style="-fx-background-color: yellow; -fx-border-color: black;" text="Limpar" />
            <Label layoutX="202.0" layoutY="44.0" text="Id">
               <font>
                  <Font name="Arial" size="18.0" />
               </font>
            </Label>
            <TextField fx:id="txtId" disable="true" layoutX="231.0" layoutY="41.0" style="-fx-border-color: black;" />
         </children>
      </Pane>
   </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="550.0" prefWidth="700.0" style="-fx-background-color: #18181b; -fx-base: #18181b;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.MainController">
    <children>
        <Label layoutX="40.0" layoutY="25.0" text="GERENCIAR STREAMERS" textFill="#a970ff">
            <font><Font name="System Bold" size="24.0" /></font>
        </Label>

        <GridPane layoutX="40.0" layoutY="80.0" hgap="15.0" vgap="20.0" style="-fx-background-color: #1f1f23; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #3a3a3d; -fx-border-radius: 10;">
            <columnConstraints>
                <ColumnConstraints prefWidth="80.0" halignment="RIGHT" />
                <ColumnConstraints prefWidth="180.0" />
                <ColumnConstraints prefWidth="80.0" halignment="RIGHT" />
                <ColumnConstraints prefWidth="180.0" />
            </columnConstraints>

            <Label text="Nome:" textFill="#efeff1" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <TextField fx:id="txtNome" promptText="Ex: Alanzoka" style="-fx-background-color: #0e0e10; -fx-text-fill: white; -fx-border-color: #53535f; -fx-border-radius: 5; -fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Conteúdo:" textFill="#efeff1" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <TextField fx:id="txtConteudo" promptText="Ex: Variedades" style="-fx-background-color: #0e0e10; -fx-text-fill: white; -fx-border-color: #53535f; -fx-border-radius: 5; -fx-background-radius: 5;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

            <Label text="Plataforma:" textFill="#efeff1" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <ComboBox fx:id="cbPlataforma" maxWidth="Infinity" style="-fx-background-color: #0e0e10; -fx-border-color: #53535f; -fx-border-radius: 5; -fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Seguidores:" textFill="#efeff1" GridPane.columnIndex="2" GridPane.rowIndex="1">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <Spinner fx:id="spSeguidores" editable="true" maxWidth="Infinity" style="-fx-control-inner-background: #0e0e10; -fx-background-color: #0e0e10; -fx-border-color: #53535f; -fx-border-radius: 5; -fx-background-radius: 5;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
        </GridPane>

        <HBox layoutX="40.0" layoutY="220.0" spacing="15.0">
            <Button fx:id="btnSalvar" onAction="#salvar" prefWidth="100.0" text="Salvar" style="-fx-background-color: #9146ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" />
            <Button fx:id="btnEditar" onAction="#editar" prefWidth="100.0" text="Editar" style="-fx-background-color: #00e5ff; -fx-text-fill: #000000; -fx-font-weight: bold; -fx-background-radius: 5;" />
            <Button fx:id="btnDeletar" onAction="#deletar" prefWidth="100.0" text="Deletar" style="-fx-background-color: #ff5252; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" />
            <Button fx:id="btnLimpar" onAction="#limpar" prefWidth="100.0" text="Limpar" style="-fx-background-color: #3a3a3d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" />
        </HBox>

        <Label fx:id="lblMensagem" layoutX="40.0" layoutY="265.0" textFill="WHITE">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>
        <Label fx:id="lblContador" layoutX="520.0" layoutY="265.0" text="Total: 0" textFill="#a970ff">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>

        <TableView fx:id="tblStreamer" layoutX="40.0" layoutY="295.0" onMouseClicked="#carregarCampos" prefHeight="215.0" prefWidth="620.0" style="-fx-background-color: #1f1f23; -fx-border-color: #3a3a3d;">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50.0" />
                <TableColumn fx:id="colNome" text="Nome" prefWidth="140.0" />
                <TableColumn fx:id="colConteudo" text="Conteúdo" prefWidth="140.0" />
                <TableColumn fx:id="colPlataforma" text="Plataforma" prefWidth="130.0" />
                <TableColumn fx:id="colSeguidores" text="Seguidores" prefWidth="140.0" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>
    </children>
</AnchorPane>